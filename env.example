# JIRA Cloud
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your_jira_api_token

# Bitbucket Cloud
BITBUCKET_WORKSPACE=your-bitbucket-workspace
BITBUCKET_API_KEY=your_bitbucket_api_key

# Workspace (root folder containing all repos)
WORKSPACE_PATH=/path/to/your/workspace

# The JIRA account ID (or display name) that triggers codex when assigned
# Find your account ID at: JIRA_URL/rest/api/3/myself
TRIGGER_ASSIGNEE=your_jira_account_id

# Webhook server
WEBHOOK_PORT=8080
# Optional: shared secret configured in JIRA webhook settings
WEBHOOK_SECRET=
