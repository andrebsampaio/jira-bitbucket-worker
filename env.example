# JIRA Cloud
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@example.com
JIRA_TOKEN=your_jira_api_token

# Bitbucket Cloud
BITBUCKET_WORKSPACE=your-bitbucket-workspace
# Optional: override Bitbucket credentials (defaults to JIRA_USER/JIRA_TOKEN)
BITBUCKET_USER=your-email@example.com
BITBUCKET_TOKEN=your_atlassian_api_token

# Workspace (root folder containing all repos)
WORKSPACE_PATH=/path/to/your/workspace

# The JIRA account ID (or display name) that triggers codex when assigned
# Find your account ID at: JIRA_URL/rest/api/3/myself
TRIGGER_ASSIGNEE=your_jira_account_id

# Webhook server
WEBHOOK_PORT=8080
# Optional: shared secret configured in JIRA webhook settings
WEBHOOK_SECRET=

# PR Comment Bot
# The mention trigger in Bitbucket PR comments (e.g., "@andrebot fix this")
BOT_MENTION=@andrebot
# Comma-separated phrases that trigger a PR review when the bot is mentioned
BOT_REVIEW_KEYWORDS=review,please review,review please
# Comma-separated phrases that trigger fixing all open inline comments on the PR
BOT_FIX_ALL_KEYWORDS=fix all,fix all comments,fix them all,fix all open comments,address all,address all comments
